		ARRAY_START_1 += 2
		Length = buffer.readu16(RecieveBuffer, OPERATION_OFFSET_1)
		Item_1.title = buffer.readstring(RecieveBuffer, Read(Length), Length)
		-- Read 2
		local OPERATION_OFFSET_2 = ARRAY_START_1
		ARRAY_START_1 += 2
		Length = buffer.readu16(RecieveBuffer, OPERATION_OFFSET_2)
		Item_1.desc = buffer.readstring(RecieveBuffer, Read(Length), Length)
		-- Read 1
		local OPERATION_OFFSET_3 = ARRAY_START_1
		ARRAY_START_1 += 1
		Item_1.kind = buffer.readu8(RecieveBuffer, OPERATION_OFFSET_3)
		-- Read 2
		local OPERATION_OFFSET_4 = ARRAY_START_1
		ARRAY_START_1 += 2
		Length = buffer.readu16(RecieveBuffer, OPERATION_OFFSET_4)
		Item_1.weapon = buffer.readstring(RecieveBuffer, Read(Length), Length)
		table.insert(Value, Item_1)
	end
	-- END ARRAY
	return Value
end

function SerdesFunctions.WriteEVENT_ChooseCard(Value: number): ()
	-- Allocate BLOCK: 2 bytes
	local BLOCK_START = Allocate(2)
	buffer.writeu8(SendBuffer, BLOCK_START + 0, 10)
	buffer.writeu8(SendBuffer, BLOCK_START + 1, Value)
end

function SerdesFunctions.WriteEVENT_Aim(Value: Vector3): ()
	-- Allocate BLOCK: 13 bytes
	local BLOCK_START = Allocate(13)
	buffer.writeu8(SendBuffer, BLOCK_START + 0, 1)
	local Vector = Value
	buffer.writef32(SendBuffer, BLOCK_START + 1, Vector.X)
	buffer.writef32(SendBuffer, BLOCK_START + 5, Vector.Y)
	buffer.writef32(SendBuffer, BLOCK_START + 9, Vector.Z)
end

function SerdesFunctions.WriteEVENT_UseSkill(Value: number): ()
	-- Allocate BLOCK: 2 bytes
	local BLOCK_START = Allocate(2)
	buffer.writeu8(SendBuffer, BLOCK_START + 0, 11)
	buffer.writeu8(SendBuffer, BLOCK_START + 1, Value)
end

function SerdesFunctions.ReadEVENT_GameOver(): ({ time: number, level: number })
	-- Read BLOCK: 6 bytes
	local BLOCK_START = Read(6)
	local Value = {} :: any
	Value.time = buffer.readf32(RecieveBuffer, BLOCK_START + 0)
	Value.level = buffer.readu16(RecieveBuffer, BLOCK_START + 4)
	return Value
end

function SerdesFunctions.WriteEVENT_Restart(Value: number): ()
	-- Allocate BLOCK: 2 bytes
	local BLOCK_START = Allocate(2)
	buffer.writeu8(SendBuffer, BLOCK_START + 0, 13)
	buffer.writeu8(SendBuffer, BLOCK_START + 1, Value)
end

function SerdesFunctions.ReadEVENT_Weapons(): ({ string })
	-- Read BLOCK: 2 bytes
	local BLOCK_START = Read(2)
	-- START ARRAY
	local Length = buffer.readu16(RecieveBuffer, BLOCK_START + 0)
	if Length < 0 then error(`Expected "Length" to be larger than 0, got {Length} instead.`) end
	if Length > 65535 then error(`Expected "Length" to be smaller than 65535, got {Length} instead.`) end
	local Value = table.create(Length)
		-- Read BLOCK: 2 bytes
	local ARRAY_START_1 = Read(2 * Length)
	for Index = 1, Length do
		-- Read 2
		local OPERATION_OFFSET_0 = ARRAY_START_1
		ARRAY_START_1 += 2
		Length = buffer.readu16(RecieveBuffer, OPERATION_OFFSET_0)
		local Item_1 = buffer.readstring(RecieveBuffer, Read(Length), Length)
		table.insert(Value, Item_1)
	end
	-- END ARRAY
	return Value
end

function SerdesFunctions.ReadEVENT_Stats(): ({ level: number, xp: number, xpNext: number, hp: number, maxHp: number })
	-- Read BLOCK: 14 bytes
	local BLOCK_START = Read(14)
	local Value = {} :: any
	Value.level = buffer.readu16(RecieveBuffer, BLOCK_START + 0)
	Value.xp = buffer.readu32(RecieveBuffer, BLOCK_START + 2)
	Value.xpNext = buffer.readu32(RecieveBuffer, BLOCK_START + 6)
	Value.hp = buffer.readu16(RecieveBuffer, BLOCK_START + 10)
	Value.maxHp = buffer.readu16(RecieveBuffer, BLOCK_START + 12)
	return Value
end

